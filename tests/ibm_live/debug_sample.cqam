#! qubits 4
.code
    QPREP Q0, 1
    QOBSERVE H0, Q0, SAMPLE
    ILDI R0, 0
    ILDI R1, 0
    ECALL PRINT_HIST

    QPREP Q1, 1
    QOBSERVE H1, Q1, SAMPLE
    ILDI R0, 1
    ILDI R1, 0
    ECALL PRINT_HIST

    QPREP Q2, 1
    QOBSERVE H2, Q2, SAMPLE
    ILDI R0, 2
    ILDI R1, 0
    ECALL PRINT_HIST
    HALT

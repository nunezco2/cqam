# examples/test_permutation.cqam
# Test the PERMUTATION kernel (kernel_id = 10)
#
# Four tests:
#   1. SWAP on 2 qubits: sigma = [0, 2, 1, 3] swaps states 1 <-> 2
#   2. Cyclic left shift on 3 qubits: sigma(k) = (k+1) mod 8
#   3. Modular multiplication oracle on 3 qubits: sigma(y) = 2y mod 7, sigma(7) = 7
#   4. Identity permutation (no-op) on 2 qubits
#
# Convention: qubit 0 is MSB. QFLIP mask=1 flips qubit 0 (MSB),
# so for 2 qubits it produces state index 2, for 3 qubits index 4.
#
#! qubits 2

.data
    .org 1000
banner:
    .ascii "=== Permutation Kernel Test ===\n"
t1_hdr:
    .ascii "--- Test 1: SWAP on 2 qubits ---\n"
t1_pre:
    .ascii "Pre-perm  P(1)=%f  P(2)=%f\n"
t1_post:
    .ascii "Post-perm P(1)=%f  P(2)=%f\n"
t1_ok:
    .ascii "Test 1 PASS: states 1<->2 swapped correctly\n"
t1_fail:
    .ascii "Test 1 FAIL\n"
t2_hdr:
    .ascii "--- Test 2: Cyclic shift on 3 qubits ---\n"
t2_pre:
    .ascii "Pre-shift  P(0)=%f P(1)=%f\n"
t2_post:
    .ascii "Post-shift P(0)=%f P(1)=%f\n"
t2_ok:
    .ascii "Test 2 PASS: |0> shifted to |1>\n"
t2_fail:
    .ascii "Test 2 FAIL\n"
t3_hdr:
    .ascii "--- Test 3: Mod-mult oracle (a=2, N=7) ---\n"
t3_pre:
    .ascii "Pre-oracle  P(4)=%f\n"
t3_post:
    .ascii "Post-oracle P(4)=%f P(1)=%f\n"
t3_ok:
    .ascii "Test 3 PASS: |4> -> |sigma(4)=1>\n"
t3_fail:
    .ascii "Test 3 FAIL\n"
t4_hdr:
    .ascii "--- Test 4: Identity permutation ---\n"
t4_pre:
    .ascii "Pre-id   P(2)=%f P(1)=%f\n"
t4_post:
    .ascii "Post-id  P(2)=%f P(1)=%f\n"
t4_ok:
    .ascii "Test 4 PASS: identity preserves state\n"
t4_fail:
    .ascii "Test 4 FAIL\n"
done_msg:
    .ascii "=== All permutation tests complete ===\n"

.code

# ===========================================================================
# Print banner
# ===========================================================================
    ILDI R0, @banner
    ILDI R1, @banner.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR

# ===========================================================================
# Test 1: SWAP on 2 qubits (dim = 4)
# Permutation: sigma = [0, 2, 1, 3]
# This swaps basis states 1 <-> 2.
# Start: state index 2 (via QFLIP mask=1 on |00>, qubit 0=MSB=bit1)
# Expect: state index 1 after permutation (sigma(2)=1)
# ===========================================================================
    ILDI R0, @t1_hdr
    ILDI R1, @t1_hdr.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR

    # Store permutation table at CMEM[200..203]
    ILDI R5, 0
    ISTR R5, 200        # sigma(0) = 0
    ILDI R5, 2
    ISTR R5, 201        # sigma(1) = 2
    ILDI R5, 1
    ISTR R5, 202        # sigma(2) = 1
    ILDI R5, 3
    ISTR R5, 203        # sigma(3) = 3

    # Prepare state index 2: |00> then flip qubit 0 (MSB)
    QPREP Q0, ZERO          # Q0 = |00>
    ILDI R6, 1           # mask = bit 0 -> qubit 0 (MSB) -> state index 2
    QFLIP Q0, Q0, R6     # Q0 = state index 2

    # Apply SWAP permutation: sigma(2)=1
    ILDI R0, 200
    ILDI R1, 0
    QKERNEL PERM, Q0, Q0, R0, R1

    # Verify via destructive measurement: expect state 1 after swap
    QOBSERVE H0, Q0
    HREDUCE ARGMX, H0, R10
    ILDI R11, 1
    IEQ R10, R10, R11
    JIF R10, t1_pass
    ILDI R0, @t1_fail
    ILDI R1, @t1_fail.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR
    JMP t1_end
LABEL: t1_pass
    ILDI R0, @t1_ok
    ILDI R1, @t1_ok.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR
LABEL: t1_end

# ===========================================================================
# Test 2: Cyclic left shift on 3 qubits (dim = 8)
# sigma = [1, 2, 3, 4, 5, 6, 7, 0]: |k> -> |(k+1) mod 8>
# Start: state index 0 (|000>)
# Expect: state index 1 (sigma(0)=1)
# ===========================================================================
    ILDI R0, @t2_hdr
    ILDI R1, @t2_hdr.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR

    # Store permutation table at CMEM[300..307]
    ILDI R5, 1
    ISTR R5, 300
    ILDI R5, 2
    ISTR R5, 301
    ILDI R5, 3
    ISTR R5, 302
    ILDI R5, 4
    ISTR R5, 303
    ILDI R5, 5
    ISTR R5, 304
    ILDI R5, 6
    ISTR R5, 305
    ILDI R5, 7
    ISTR R5, 306
    ILDI R5, 0
    ISTR R5, 307

    # Prepare |000> (3 qubits)
    ILDI R7, 3
    QPREPN Q1, ZERO, R7     # Q1 = |000>

    # Apply cyclic shift
    ILDI R0, 300
    ILDI R1, 0
    QKERNEL PERM, Q1, Q1, R0, R1

    # Verify via destructive measurement: expect state 1 (sigma(0)=1)
    QOBSERVE H0, Q1
    HREDUCE ARGMX, H0, R10
    ILDI R11, 1
    IEQ R10, R10, R11
    JIF R10, t2_pass
    ILDI R0, @t2_fail
    ILDI R1, @t2_fail.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR
    JMP t2_end
LABEL: t2_pass
    ILDI R0, @t2_ok
    ILDI R1, @t2_ok.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR
LABEL: t2_end

# ===========================================================================
# Test 3: Modular multiplication oracle (a=2, N=7) on 3 qubits
# sigma(y) = 2y mod 7 for y in {0..6}, sigma(7) = 7
# Table: [0, 2, 4, 6, 1, 3, 5, 7]
# Start: state index 4 (QFLIP mask=1 on 3-qubit |000>)
# Expect: state index sigma(4) = 1
# ===========================================================================
    ILDI R0, @t3_hdr
    ILDI R1, @t3_hdr.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR

    # Store permutation table at CMEM[400..407]
    ILDI R5, 0
    ISTR R5, 400
    ILDI R5, 2
    ISTR R5, 401
    ILDI R5, 4
    ISTR R5, 402
    ILDI R5, 6
    ISTR R5, 403
    ILDI R5, 1
    ISTR R5, 404
    ILDI R5, 3
    ISTR R5, 405
    ILDI R5, 5
    ISTR R5, 406
    ILDI R5, 7
    ISTR R5, 407

    # Prepare state index 4 (3 qubits: flip qubit 0 -> MSB -> bit 2 -> index 4)
    ILDI R7, 3
    QPREPN Q2, ZERO, R7
    ILDI R6, 1
    QFLIP Q2, Q2, R6     # state index 4

    # Apply mod-mult oracle: sigma(4) = 1
    ILDI R0, 400
    ILDI R1, 0
    QKERNEL PERM, Q2, Q2, R0, R1

    # Verify via destructive measurement: expect state 1 (sigma(4)=1)
    QOBSERVE H0, Q2
    HREDUCE ARGMX, H0, R10
    ILDI R11, 1
    IEQ R10, R10, R11
    JIF R10, t3_pass
    ILDI R0, @t3_fail
    ILDI R1, @t3_fail.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR
    JMP t3_end
LABEL: t3_pass
    ILDI R0, @t3_ok
    ILDI R1, @t3_ok.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR
LABEL: t3_end

# ===========================================================================
# Test 4: Identity permutation on 2 qubits (no-op)
# sigma = [0, 1, 2, 3]
# Start: state index 2 (same as Test 1 setup)
# Expect: state index 2 unchanged
# ===========================================================================
    ILDI R0, @t4_hdr
    ILDI R1, @t4_hdr.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR

    # Store identity permutation at CMEM[500..503]
    ILDI R5, 0
    ISTR R5, 500
    ILDI R5, 1
    ISTR R5, 501
    ILDI R5, 2
    ISTR R5, 502
    ILDI R5, 3
    ISTR R5, 503

    # Prepare state index 2 (2 qubits)
    QPREP Q3, ZERO
    ILDI R6, 1
    QFLIP Q3, Q3, R6     # state index 2

    # Apply identity permutation
    ILDI R0, 500
    ILDI R1, 0
    QKERNEL PERM, Q3, Q3, R0, R1

    # Verify via destructive measurement: expect state 2 (unchanged)
    QOBSERVE H0, Q3
    HREDUCE ARGMX, H0, R10
    ILDI R11, 2
    IEQ R10, R10, R11
    JIF R10, t4_pass
    ILDI R0, @t4_fail
    ILDI R1, @t4_fail.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR
    JMP t4_end
LABEL: t4_pass
    ILDI R0, @t4_ok
    ILDI R1, @t4_ok.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR
LABEL: t4_end

# ===========================================================================
# Done
# ===========================================================================
    ILDI R0, @done_msg
    ILDI R1, @done_msg.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR

    HALT

# examples/swap_test.cqam
# Quantum SWAP Test — compare two quantum states
#
# Algorithm: The SWAP test determines the overlap |<psi|phi>|^2 between
# two quantum states without full tomography:
#   1. Prepare an ancilla qubit in |0>
#   2. Apply Hadamard to ancilla
#   3. Controlled-SWAP between |psi> and |phi> (conditioned on ancilla)
#   4. Apply Hadamard to ancilla
#   5. Measure ancilla: P(0) = (1 + |<psi|phi>|^2) / 2
#
# In CQAM, we approximate this by:
#   - Preparing two states in separate Q registers
#   - Using QOBSERVE to extract distribution and density matrix elements
#   - Computing the fidelity classically from the observations
#
# Also demonstrates a "poor man's fidelity" via distribution comparison.
#
#! qubits 16
#
# All operations are register-level — no gate-level ops required.

.data
    .org 1000
banner:
    .ascii "=== SWAP Test ===\n"
inp_fmt:
    .ascii "Inputs: qubits=%d\n"
res_fmt:
    .ascii "Results: same_diff=%f, diff_diff=%f\n"

.code

# --- Print banner and inputs ---
    ILDI R0, @banner
    ILDI R1, @banner.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR

    ILDI R0, @inp_fmt
    ILDI R1, @inp_fmt.len
    ILDI R15, 1
    ISUB R1, R1, R15
    IQCFG R2              # R2 = qubit count from config
    ECALL PRINT_STR

# --- Setup ---
    ILDI R0, 0           # R0 = state |0> / row index
    ILDI R1, 1           # R1 = state |1> / col index
    ILDI R2, 0           # R2 = ctx

# ===============================================
# Test 1: Same state — overlap should be 1.0
# ===============================================
    QPREP Q0, 1          # Q0 = uniform superposition
    QPREP Q1, 1          # Q1 = uniform superposition (identical)

# Observe both distributions (destructive)
    QOBSERVE H4, Q0
    QOBSERVE H5, Q1

# Compare means and variances from observed distributions
    HREDUCE MEANT, H4, F0   # F0 = mean(Q0)
    HREDUCE MEANT, H5, F1   # F1 = mean(Q1)
    HREDUCE VARNC, H4, F2   # F2 = var(Q0)
    HREDUCE VARNC, H5, F3   # F3 = var(Q1)

# Compute mean difference as fidelity proxy
    FSUB F4, F0, F1      # F4 = mean_diff
    FMUL F4, F4, F4      # F4 = mean_diff^2 (should be ~0 for identical)

# Compute diagonal element difference from observed distributions
    FSUB F7, F2, F3      # F7 = variance difference (should be ~0)

# Print measurement histogram for same-state test (top-10 for 16-qubit state)
    ILDI R0, 4            # H4 = distribution from Q0 (same-state test)
    ILDI R1, 3            # Mode 3: top-K
    ILDI R2, 10           # Show top 10
    ECALL PRINT_HIST

# ===============================================
# Test 2: Different states — overlap should be < 1
# ===============================================
    QPREP Q2, 1          # Q2 = uniform
    QPREP Q3, 0          # Q3 = zero state (very different!)

# Observe both (destructive)
    QOBSERVE H4, Q2
    QOBSERVE H5, Q3
    HREDUCE MEANT, H4, F8   # mean(uniform)
    HREDUCE MEANT, H5, F9   # mean(zero)
    FSUB F10, F8, F9     # difference in means (should be large)
    FMUL F10, F10, F10   # squared difference

    # Print measurement histogram for different-state test (top-10 for 16-qubit state)
    ILDI R0, 4            # H4 = distribution from Q2 (different-state test)
    ILDI R1, 3            # Mode 3: top-K
    ILDI R2, 10           # Show top 10
    ECALL PRINT_HIST

# ===============================================
# Test 3: Parameterized states — vary overlap continuously
# ===============================================
    QPREP Q4, 1          # Start uniform
    FLDI F11, 1          # theta = 1
    FLDI F12, 0          # unused
    QKERNELF DROT, Q4, Q4, F11, F12  # Rotate by theta=1

    QPREP Q5, 1          # Start uniform
    FLDI F13, 2          # theta = 2 (different rotation)
    QKERNELF DROT, Q5, Q5, F13, F12  # Rotate by theta=2

# Compare distributions (destructive)
    QOBSERVE H0, Q4
    QOBSERVE H1, Q5
    HREDUCE MEANT, H0, F14
    HREDUCE MEANT, H1, F15
    FSUB F14, F14, F15   # Mean difference

# --- Store all results ---
    FSTR F4, 0           # CMEM[0] = same-state squared mean diff (~0)
    FSTR F10, 1          # CMEM[1] = diff-state squared mean diff (large)
    FSTR F7, 2           # CMEM[2] = variance difference
    FSTR F14, 3          # CMEM[3] = parameterized state mean diff

# --- Print results ---
    ILDI R0, @res_fmt
    ILDI R1, @res_fmt.len
    ILDI R15, 1
    ISUB R1, R1, R15
    FLDM F1, 0           # F1 = same-state diff (%f arg 1)
    FLDM F2, 1           # F2 = diff-state diff (%f arg 2)
    ECALL PRINT_STR

    HALT

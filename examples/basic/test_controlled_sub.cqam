# examples/test_controlled_sub.cqam
# Test CONTROLLED_U with sub-kernel overrides: PERMUTATION (10) and DIAGONAL_UNITARY (9)
#
# Test A: Controlled-PERMUTATION (C-PERM)
#   3 qubits: qubit 0 = control, qubits 1-2 = target (dim=4 target states)
#   Permutation: cyclic shift sigma = [1, 2, 3, 0] on 4 target states
#   A1: Control=|0>, target=|01> -> state |001>=1. Expect: unchanged (P(1)=1)
#   A2: Control=|1>, target=|01> -> state |101>=5. Expect: sigma(01)=10,
#       so target becomes |10>, full state |110>=6. (P(6)=1)
#
# Test B: Controlled-DIAGONAL_UNITARY (C-DIAG)
#   3 qubits: qubit 0 = control, qubits 1-2 = target (dim=4 target states)
#   Diagonal: d = [(1,0), (-1,0), (1,0), (1,0)] -- phase flip on target |01>
#   B1: Control=|0>, target=|01> -> state |001>=1. Expect: unchanged (P(1)=1)
#   B2: Control=|1>, target=|01> -> state |101>=5. Diagonal flips phase of
#       target |01>, so amplitude becomes -1. Probability still 1. (P(5)=1)
#       To detect the phase, we also test with a superposition.
#   B3: Control=|1>, target=(|00>+|01>)/sqrt(2). Start: (|100>+|101>)/sqrt(2).
#       After C-DIAG: (|100>-|101>)/sqrt(2). Apply Hadamard to qubit 2 and
#       check that the phase flip is detected (probability shifts).
#       Actually, simpler: just verify probabilities are preserved for B2,
#       then test superposition where the diagonal creates interference.
#
# CMEM layout:
#   100-103: Permutation table (4 entries)
#   110-117: Diagonal entries (4 complex pairs = 8 cells) via .c64
#   200-204: C-U parameter block for C-PERM
#   210-214: C-U parameter block for C-DIAG
#
#! qubits 3

.data
    .org 110
c_diag_data:
    .c64 1.0J0.0, -1.0J0.0, 1.0J0.0, 1.0J0.0

    .org 1000
banner:
    .ascii "=== Controlled Sub-Kernel Test ===\n"
ta_hdr:
    .ascii "--- Test A: Controlled-PERMUTATION ---\n"
ta1_pre:
    .ascii "A1 ctrl=0: P(1)=%f (expect 1.0)\n"
ta1_ok:
    .ascii "A1 PASS: ctrl=0 leaves state unchanged\n"
ta1_fail:
    .ascii "A1 FAIL: ctrl=0 should not permute\n"
ta2_pre:
    .ascii "A2 ctrl=1: P(5)=%f P(6)=%f (expect 0, 1)\n"
ta2_ok:
    .ascii "A2 PASS: ctrl=1 permutes target correctly\n"
ta2_fail:
    .ascii "A2 FAIL: ctrl=1 permutation incorrect\n"
tb_hdr:
    .ascii "--- Test B: Controlled-DIAGONAL_UNITARY ---\n"
tb1_pre:
    .ascii "B1 ctrl=0: P(1)=%f (expect 1.0)\n"
tb1_ok:
    .ascii "B1 PASS: ctrl=0 leaves state unchanged\n"
tb1_fail:
    .ascii "B1 FAIL: ctrl=0 should not apply diagonal\n"
tb2_pre:
    .ascii "B2 ctrl=1: P(5)=%f (expect 1.0)\n"
tb2_ok:
    .ascii "B2 PASS: ctrl=1 preserves probability (phase only)\n"
tb2_fail:
    .ascii "B2 FAIL: ctrl=1 diagonal incorrect\n"
done_msg:
    .ascii "=== All controlled sub-kernel tests complete ===\n"

.code

# ===========================================================================
# Print banner
# ===========================================================================
    ILDI R15, 1          # constant 1

    ILDI R0, @banner
    ILDI R1, @banner.len
    ISUB R1, R1, R15
    ECALL PRINT_STR

# ===========================================================================
# Set up permutation table at CMEM[100..103]
# Cyclic shift: sigma = [1, 2, 3, 0]
# ===========================================================================
    ILDI R5, 1
    ISTR R5, 100        # sigma(0) = 1
    ILDI R5, 2
    ISTR R5, 101        # sigma(1) = 2
    ILDI R5, 3
    ISTR R5, 102        # sigma(2) = 3
    ILDI R5, 0
    ISTR R5, 103        # sigma(3) = 0

# ===========================================================================
# Set up C-U parameter block for C-PERM at CMEM[200..204]
#   [200] = sub_kernel_id = 10 (PERMUTATION)
#   [201] = power = 0
#   [202] = permutation table CMEM address = 100
#   [203] = unused (0)
#   [204] = target_qubits = 2
# ===========================================================================
    ILDI R5, 10
    ISTR R5, 200        # sub_kernel_id = 10
    ILDI R5, 0
    ISTR R5, 201        # power = 0
    ILDI R5, 100
    ISTR R5, 202        # sub-data address = 100
    ILDI R5, 0
    ISTR R5, 203        # unused
    ILDI R5, 2
    ISTR R5, 204        # target_qubits = 2

# ===========================================================================
# Set up C-U parameter block for C-DIAG at CMEM[210..214]
#   [210] = sub_kernel_id = 9 (DIAGONAL_UNITARY)
#   [211] = power = 0
#   [212] = diagonal data CMEM address = 110
#   [213] = unused (0)
#   [214] = target_qubits = 2
# ===========================================================================
    ILDI R5, 9
    ISTR R5, 210        # sub_kernel_id = 9
    ILDI R5, 0
    ISTR R5, 211        # power = 0
    ILDI R5, 110
    ISTR R5, 212        # sub-data address = 110
    ILDI R5, 0
    ISTR R5, 213        # unused
    ILDI R5, 2
    ISTR R5, 214        # target_qubits = 2

# ===========================================================================
# Test A: Controlled-PERMUTATION
# ===========================================================================
    ILDI R0, @ta_hdr
    ILDI R1, @ta_hdr.len
    ISUB R1, R1, R15
    ECALL PRINT_STR

# ---------------------------------------------------------------------------
# Test A1: Control=|0>, target=|01> -> state |001> = index 1
# Apply C-PERM with ctrl qubit 0. Since ctrl=0, permutation should NOT apply.
# Expect: P(1) = 1.0 (unchanged)
#
# Qubit ordering: qubit 0=MSB, qubit 2=LSB. QFLIP mask bits: bit k -> qubit k.
# mask=4 (bit 2) -> qubit 2 (LSB) -> flips bit position 0 -> state |001>=1
# ---------------------------------------------------------------------------
    QPREP Q0, 0                    # Q0 = |000>
    ILDI R6, 4                     # mask=4 -> flip qubit 2 (LSB) -> state |001>=1
    QFLIP Q0, Q0, R6

    # Apply C-PERM: QKERNEL CTLU, Q0, Q0, R_ctrl, R_param_base
    ILDI R8, 0                     # R8 = control qubit index = 0
    ILDI R9, 200                   # R9 = CMEM base of param block
    QKERNEL CTLU, Q0, Q0, R8, R9

    # Sample P(1) -- expect 1.0
    ILDI R9, 1
    QOBSERVE H0, Q0, 1, R9, R9
    HREDUCE REALP, H0, F1


    ILDI R0, @ta1_pre
    ILDI R1, @ta1_pre.len
    ISUB R1, R1, R15
    ECALL PRINT_STR

    # Check F1 == 1.0
    FLDI F5, 1
    FEQ R10, F1, F5
    JIF R10, ta1_pass
    ILDI R0, @ta1_fail
    ILDI R1, @ta1_fail.len
    ISUB R1, R1, R15
    ECALL PRINT_STR
    JMP ta1_end
LABEL: ta1_pass
    ILDI R0, @ta1_ok
    ILDI R1, @ta1_ok.len
    ISUB R1, R1, R15
    ECALL PRINT_STR
LABEL: ta1_end

# ---------------------------------------------------------------------------
# Test A2: Control=|1>, target=|01> -> state |101> = index 5
# Apply C-PERM. Since ctrl=1, permutation SHOULD apply.
# target |01> = target index 1, sigma(1)=2, so target becomes |10>.
# New state = |1,1,0> = |110> = index 6.
# Expect: P(5)=0, P(6)=1.0
# ---------------------------------------------------------------------------
    QPREP Q0, 0                    # Q0 = |000>
    ILDI R6, 5                     # mask=5 = binary 101 -> flip qubit 0 (MSB) and qubit 2 (LSB)
    QFLIP Q0, Q0, R6              # state |101> = index 5

    ILDI R8, 0                     # control qubit = 0
    ILDI R9, 200                   # param block at CMEM[200]
    QKERNEL CTLU, Q0, Q0, R8, R9

    # Verify: expect state 6 (P(6)=1)
    QOBSERVE H0, Q0
    HREDUCE ARGMX, H0, R10           # R10 = argmax -- expect 6

    # Check R10 == 6
    ILDI R11, 6
    IEQ R10, R10, R11
    JIF R10, ta2_pass
    ILDI R0, @ta2_fail
    ILDI R1, @ta2_fail.len
    ISUB R1, R1, R15
    ECALL PRINT_STR
    JMP ta2_end
LABEL: ta2_pass
    ILDI R0, @ta2_ok
    ILDI R1, @ta2_ok.len
    ISUB R1, R1, R15
    ECALL PRINT_STR
LABEL: ta2_end

# ===========================================================================
# Test B: Controlled-DIAGONAL_UNITARY
# ===========================================================================
    ILDI R0, @tb_hdr
    ILDI R1, @tb_hdr.len
    ISUB R1, R1, R15
    ECALL PRINT_STR

# ---------------------------------------------------------------------------
# Test B1: Control=|0>, target=|01> -> state |001> = index 1
# Apply C-DIAG. Since ctrl=0, diagonal should NOT apply.
# Expect: P(1) = 1.0 (unchanged)
# mask=4 (bit 2) -> flip qubit 2 (LSB) -> state |001>=1
# ---------------------------------------------------------------------------
    QPREP Q0, 0                    # Q0 = |000>
    ILDI R6, 4                     # mask=4 -> flip qubit 2 (LSB) -> |001>=1
    QFLIP Q0, Q0, R6

    ILDI R8, 0                     # control qubit = 0
    ILDI R9, 210                   # param block at CMEM[210]
    QKERNEL CTLU, Q0, Q0, R8, R9

    # Sample P(1) -- expect 1.0
    ILDI R9, 1
    QOBSERVE H0, Q0, 1, R9, R9
    HREDUCE REALP, H0, F1


    ILDI R0, @tb1_pre
    ILDI R1, @tb1_pre.len
    ISUB R1, R1, R15
    ECALL PRINT_STR

    # Check F1 == 1.0
    FLDI F5, 1
    FEQ R10, F1, F5
    JIF R10, tb1_pass
    ILDI R0, @tb1_fail
    ILDI R1, @tb1_fail.len
    ISUB R1, R1, R15
    ECALL PRINT_STR
    JMP tb1_end
LABEL: tb1_pass
    ILDI R0, @tb1_ok
    ILDI R1, @tb1_ok.len
    ISUB R1, R1, R15
    ECALL PRINT_STR
LABEL: tb1_end

# ---------------------------------------------------------------------------
# Test B2: Control=|1>, target=|01> -> state |101> = index 5
# Apply C-DIAG. Since ctrl=1, diagonal SHOULD apply.
# d[1] = (-1, 0) phase-flips target |01>. Amplitude becomes -1.
# Probability is still 1.0. Expect: P(5) = 1.0
# ---------------------------------------------------------------------------
    QPREP Q0, 0                    # Q0 = |000>
    ILDI R6, 5                     # mask=5 = 101 -> flip qubit 0 + qubit 2 -> |101>=5
    QFLIP Q0, Q0, R6

    ILDI R8, 0                     # control qubit = 0
    ILDI R9, 210                   # param block at CMEM[210]
    QKERNEL CTLU, Q0, Q0, R8, R9

    # Sample P(5) -- expect 1.0 (phase flip doesn't change probability)
    ILDI R9, 5
    QOBSERVE H0, Q0, 1, R9, R9
    HREDUCE REALP, H0, F1


    ILDI R0, @tb2_pre
    ILDI R1, @tb2_pre.len
    ISUB R1, R1, R15
    ECALL PRINT_STR

    # Check F1 == 1.0
    FLDI F5, 1
    FEQ R10, F1, F5
    JIF R10, tb2_pass
    ILDI R0, @tb2_fail
    ILDI R1, @tb2_fail.len
    ISUB R1, R1, R15
    ECALL PRINT_STR
    JMP tb2_end
LABEL: tb2_pass
    ILDI R0, @tb2_ok
    ILDI R1, @tb2_ok.len
    ISUB R1, R1, R15
    ECALL PRINT_STR
LABEL: tb2_end

# ===========================================================================
# Done
# ===========================================================================
    ILDI R0, @done_msg
    ILDI R1, @done_msg.len
    ISUB R1, R1, R15
    ECALL PRINT_STR

    HALT

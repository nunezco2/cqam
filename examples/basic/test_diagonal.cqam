# examples/test_diagonal.cqam
# Test the DIAGONAL_UNITARY kernel (kernel_id = 9)
#
# Tests:
#   1. Apply a diagonal Z-oracle that flips the phase of state |5>
#      on a uniform superposition.
#   2. Follow with Grover diffusion (DIFFUSE kernel 3) to amplify |5>.
#      After one oracle+diffusion iteration the marked state should have
#      enhanced probability.
#   3. Repeat for a second Grover iteration and measure via QOBSERVE.
#
# Note: intermediate probabilities are not observed (physical realism).
# Only the final QOBSERVE reveals the measurement outcome.
#
#! qubits 4

.data
    .org 200
diag:
    .c64 1.0J0.0,  1.0J0.0,  1.0J0.0,  1.0J0.0,
         1.0J0.0, -1.0J0.0,  1.0J0.0,  1.0J0.0,
         1.0J0.0,  1.0J0.0,  1.0J0.0,  1.0J0.0,
         1.0J0.0,  1.0J0.0,  1.0J0.0,  1.0J0.0

    .org 1000
banner:
    .ascii "=== Diagonal Unitary Test ===\n"
pre_msg:
    .ascii "Pre-oracle  P(|5>)  = %f\n"
post_msg:
    .ascii "Post-oracle P(|5>)  = %f\n"
grv1_msg:
    .ascii "1 Grover iter P(|5>) = %f\n"
grv2_msg:
    .ascii "2 Grover iter P(|5>) = %f\n"
res_msg:
    .ascii "Measured argmax = %d\n"

.code

# ===========================================================================
# Print banner
# ===========================================================================
    ILDI R0, @banner
    ILDI R1, @banner.len
    IDEC R1
    ECALL PRINT_STR

# ===========================================================================
# Step 1: Prepare uniform superposition, apply diagonal oracle
# ===========================================================================
    QPREP Q0, UNIF          # Q0 = uniform superposition over 16 states

    # Runs blind — no mid-step observation (physical realism)

    # Apply diagonal oracle
    ILDI R0, @diag
    ILDI R1, @diag.len
    QKERNEL DIAG, Q0, Q0, R0, R1   # Apply diagonal unitary

# ===========================================================================
# Step 2: Grover amplification -- apply diffusion (kernel 3)
# ===========================================================================
    ILDI R0, 0
    ILDI R1, 0
    QKERNEL DIFF, Q0, Q0, R0, R1   # Diffuse
    # Runs blind — no mid-step observation (physical realism)

# ===========================================================================
# Step 3: Second Grover iteration (oracle + diffusion)
# ===========================================================================
    # Re-apply oracle
    ILDI R0, @diag
    ILDI R1, @diag.len
    QKERNEL DIAG, Q0, Q0, R0, R1

    # Diffusion
    ILDI R0, 0
    ILDI R1, 0
    QKERNEL DIFF, Q0, Q0, R0, R1

# ===========================================================================
# Final: destructive measurement -- check that argmax is 5
# ===========================================================================
    QOBSERVE H4, Q0             # H4 = full distribution (destructive)
    HREDUCE ARGMX, H4, R2          # R2 = argmax (most probable state index)

    # Print result
    ILDI R0, @res_msg
    ILDI R1, @res_msg.len
    IDEC R1
    ECALL PRINT_STR

    HALT

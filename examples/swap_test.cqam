# examples/swap_test.cqam
# Quantum SWAP Test — compare two quantum states
#
# Algorithm: The SWAP test determines the overlap |<psi|phi>|^2 between
# two quantum states without full tomography:
#   1. Prepare an ancilla qubit in |0>
#   2. Apply Hadamard to ancilla
#   3. Controlled-SWAP between |psi> and |phi> (conditioned on ancilla)
#   4. Apply Hadamard to ancilla
#   5. Measure ancilla: P(0) = (1 + |<psi|phi>|^2) / 2
#
# In CQAM, we approximate this by:
#   - Preparing two states in separate Q registers
#   - Using the QSAMPLE AMP mode to extract density matrix elements
#   - Computing the fidelity classically from the observations
#
# Also demonstrates a "poor man's fidelity" via distribution comparison.
#
#! qubits 16
#
# All operations are register-level — no gate-level ops required.

.data
    .org 1000
banner:
    .ascii "=== SWAP Test ===\n"
inp_fmt:
    .ascii "Inputs: qubits=%d\n"
res_fmt:
    .ascii "Results: same_diff=%d, diff_diff=%d\n"

.code

# --- Print banner and inputs ---
    ILDI R0, @banner
    ILDI R1, @banner.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR

    ILDI R0, @inp_fmt
    ILDI R1, @inp_fmt.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ILDI R2, 16
    ECALL PRINT_STR

# --- Setup ---
    ILDI R0, 0           # R0 = state |0> / row index
    ILDI R1, 1           # R1 = state |1> / col index
    ILDI R2, 0           # R2 = ctx

# ===============================================
# Test 1: Same state — overlap should be 1.0
# ===============================================
    QPREP Q0, 0          # Q0 = uniform superposition
    QPREP Q1, 0          # Q1 = uniform superposition (identical)

# Sample both distributions
    QSAMPLE H0, Q0, 0, R0, R0   # H0 = dist of Q0
    QSAMPLE H1, Q1, 0, R0, R0   # H1 = dist of Q1

# Compare means and variances
    HREDUCE H0, F0, 10   # F0 = mean(Q0)
    HREDUCE H1, F1, 10   # F1 = mean(Q1)
    HREDUCE H0, F2, 13   # F2 = var(Q0)
    HREDUCE H1, F3, 13   # F3 = var(Q1)

# Compute mean difference as fidelity proxy
    FSUB F4, F0, F1      # F4 = mean_diff
    FMUL F4, F4, F4      # F4 = mean_diff^2 (should be ~0 for identical)

# Compare via density matrix elements
    QSAMPLE H2, Q0, 2, R0, R0   # rho_0[0][0]
    QSAMPLE H3, Q1, 2, R0, R0   # rho_1[0][0]
    HREDUCE H2, F5, 8    # F5 = real(rho_0[0][0])
    HREDUCE H3, F6, 8    # F6 = real(rho_1[0][0])
    FSUB F7, F5, F6      # F7 = difference in diagonal (should be 0)

# Clean up
    QOBSERVE H4, Q0
    QOBSERVE H5, Q1

# ===============================================
# Test 2: Different states — overlap should be < 1
# ===============================================
    QPREP Q2, 0          # Q2 = uniform
    QPREP Q3, 1          # Q3 = zero state (very different!)

# Sample
    QSAMPLE H0, Q2, 0, R0, R0
    QSAMPLE H1, Q3, 0, R0, R0
    HREDUCE H0, F8, 10   # mean(uniform)
    HREDUCE H1, F9, 10   # mean(zero)
    FSUB F10, F8, F9     # difference in means (should be large)
    FMUL F10, F10, F10   # squared difference

# AMP mode comparison
    QSAMPLE H2, Q2, 2, R0, R1   # rho_uniform[0][1]
    QSAMPLE H3, Q3, 2, R0, R1   # rho_zero[0][1]
    HREDUCE H2, Z0, 14   # Z0 = conj(rho_uniform[0][1])
    HREDUCE H3, Z1, 14   # Z1 = conj(rho_zero[0][1])
    ZSUB Z2, Z0, Z1      # Z2 = difference in off-diagonal elements

    QOBSERVE H4, Q2
    QOBSERVE H5, Q3

# ===============================================
# Test 3: Parameterized states — vary overlap continuously
# ===============================================
    QPREP Q4, 0          # Start uniform
    FLDI F11, 1          # theta = 1
    FLDI F12, 0          # unused
    QKERNELF Q4, Q4, 5, F11, F12  # Rotate by theta=1

    QPREP Q5, 0          # Start uniform
    FLDI F13, 2          # theta = 2 (different rotation)
    QKERNELF Q5, Q5, 5, F13, F12  # Rotate by theta=2

# Compare distributions
    QSAMPLE H0, Q4, 0, R0, R0
    QSAMPLE H1, Q5, 0, R0, R0
    HREDUCE H0, F14, 10
    HREDUCE H1, F15, 10
    FSUB F14, F14, F15   # Mean difference

# Store Q4 to quantum memory for later retrieval
    QSTORE Q4, 0
    QOBSERVE H2, Q5

# Reload and verify
    QLOAD Q6, 0
    QSAMPLE H3, Q6, 1, R0, R0  # P(|0>) of reloaded state
    HREDUCE H3, F15, 8
    QOBSERVE H4, Q6

# --- Store all results ---
    FSTR F4, 0           # CMEM[0] = same-state squared mean diff (~0)
    FSTR F10, 1          # CMEM[1] = diff-state squared mean diff (large)
    FSTR F7, 2           # CMEM[2] = diagonal element difference
    ZSTR Z2, 3           # CMEM[3-4] = off-diagonal difference (complex)
    FSTR F14, 5          # CMEM[5] = parameterized state mean diff

# --- Print results ---
    ILDI R0, @res_fmt
    ILDI R1, @res_fmt.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ILDM R2, 0
    ILDM R3, 1
    ECALL PRINT_STR

    HALT

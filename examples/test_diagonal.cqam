# examples/test_diagonal.cqam
# Test the DIAGONAL_UNITARY kernel (kernel_id = 9)
#
# Tests:
#   1. Apply a diagonal Z-oracle that flips the phase of state |5>
#      on a uniform superposition. QSAMPLE before and after to verify
#      probabilities are unchanged (diagonal unitary preserves |amplitude|^2).
#   2. Follow with Grover diffusion (DIFFUSE kernel 3) to amplify |5>.
#      After one oracle+diffusion iteration the marked state should have
#      enhanced probability.
#   3. Repeat for a second Grover iteration and measure via QOBSERVE.
#
#! qubits 4

.data
    .org 200
diag:
    .c64 1.0J0.0,  1.0J0.0,  1.0J0.0,  1.0J0.0,
         1.0J0.0, -1.0J0.0,  1.0J0.0,  1.0J0.0,
         1.0J0.0,  1.0J0.0,  1.0J0.0,  1.0J0.0,
         1.0J0.0,  1.0J0.0,  1.0J0.0,  1.0J0.0

    .org 1000
banner:
    .ascii "=== Diagonal Unitary Test ===\n"
pre_msg:
    .ascii "Pre-oracle  P(|5>)  = %f\n"
post_msg:
    .ascii "Post-oracle P(|5>)  = %f\n"
grv1_msg:
    .ascii "1 Grover iter P(|5>) = %f\n"
grv2_msg:
    .ascii "2 Grover iter P(|5>) = %f\n"
res_msg:
    .ascii "Measured argmax = %d\n"

.code

# ===========================================================================
# Print banner
# ===========================================================================
    ILDI R0, @banner
    ILDI R1, @banner.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR

# ===========================================================================
# Test 1: Prepare uniform superposition, sample P(|5>), apply diagonal
# ===========================================================================
    QPREP Q0, 0          # Q0 = uniform superposition over 16 states

    # Sample P(|5>) before oracle (should be 1/16 = 0.0625)
    ILDI R9, 5           # R9 = state index 5
    QSAMPLE H0, Q0, 1, R9, R9   # H0 = P(|5>) non-destructive
    HREDUCE H0, F1, 8           # F1 = real part = P(|5>)

    # Print pre-oracle probability
    ILDI R0, @pre_msg
    ILDI R1, @pre_msg.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR      # %f reads F1

    # Apply diagonal oracle
    ILDI R0, @diag
    ILDI R1, @diag.len
    QKERNEL Q0, Q0, 9, R0, R1   # Apply diagonal unitary

    # Sample P(|5>) after oracle (should still be 1/16 = 0.0625)
    # Phase flip does NOT change diagonal probabilities
    ILDI R9, 5
    QSAMPLE H1, Q0, 1, R9, R9
    HREDUCE H1, F1, 8           # F1 = P(|5>) after oracle

    # Print post-oracle probability
    ILDI R0, @post_msg
    ILDI R1, @post_msg.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR

# ===========================================================================
# Test 2: Grover amplification -- apply diffusion (kernel 3)
# ===========================================================================
    ILDI R0, 0
    ILDI R1, 0
    QKERNEL Q0, Q0, 3, R0, R1   # Diffuse

    # Sample P(|5>) after one Grover iteration
    ILDI R9, 5
    QSAMPLE H2, Q0, 1, R9, R9
    HREDUCE H2, F1, 8           # F1 = P(|5>)

    # Print
    ILDI R0, @grv1_msg
    ILDI R1, @grv1_msg.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR

# ===========================================================================
# Test 3: Second Grover iteration (oracle + diffusion)
# ===========================================================================
    # Re-apply oracle
    ILDI R0, @diag
    ILDI R1, @diag.len
    QKERNEL Q0, Q0, 9, R0, R1

    # Diffusion
    ILDI R0, 0
    ILDI R1, 0
    QKERNEL Q0, Q0, 3, R0, R1

    # Sample P(|5>) after two Grover iterations
    ILDI R9, 5
    QSAMPLE H3, Q0, 1, R9, R9
    HREDUCE H3, F1, 8           # F1 = P(|5>)

    # Print
    ILDI R0, @grv2_msg
    ILDI R1, @grv2_msg.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR

# ===========================================================================
# Final: destructive measurement -- check that argmax is 5
# ===========================================================================
    QOBSERVE H4, Q0             # H4 = full distribution (destructive)
    HREDUCE H4, R2, 12          # R2 = argmax (most probable state index)

    # Print result
    ILDI R0, @res_msg
    ILDI R1, @res_msg.len
    ILDI R15, 1
    ISUB R1, R1, R15
    ECALL PRINT_STR

    HALT
